POSTGRES_USER=zukkor
POSTGRES_PASSWORD=your_strong_password
POSTGRES_DB=zukkor_db
DATABASE_URL=postgresql+asyncpg://zukkor:your_strong_password@db:5432/zukkor_db

SECRET_KEY=your-256-bit-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Cloudinary — avatar rasmlarini doimiy saqlash (bo'sh bo'lsa lokal diskka
# tushib qolinadi, faqat dev uchun). Cloudinary dashboard'idan olinadi.
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
